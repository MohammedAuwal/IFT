<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while Flutter warms up -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <!-- Theme applied once Flutter is running -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- Set to a solid color to prevent 'ghosting' of the splash image behind the app -->
        <item name="android:windowBackground">#2A0A12</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
