<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2A0A12"
                android:endColor="#12060A"
                android:angle="315"
                android:type="linear" />
        </shape>
    </item>

    <item
        android:width="118dp"
        android:height="118dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#14FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>

    <item
        android:width="70dp"
        android:height="70dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#C29B40" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <rotate android:fromDegrees="0" android:toDegrees="0">
            <shape android:shape="rectangle">
                <size
                    android:width="1dp"
                    android:height="1dp" />
            </shape>
        </rotate>
    </item>
</layer-list>
