<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. The Background Gradient (Matches App Theme) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2A0A12"
                android:endColor="#12060A"
                android:angle="315"
                android:type="linear" />
        </shape>
    </item>

    <!-- 2. The Circle Decoration -->
    <item
        android:width="110dp"
        android:height="110dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#14FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>

    <!-- 3. The App Icon -->
    <item
        android:width="54dp"
        android:height="54dp"
        android:gravity="center">
        <bitmap
            android:src="@mipmap/ic_launcher"
            android:gravity="center" />
    </item>
</layer-list>
